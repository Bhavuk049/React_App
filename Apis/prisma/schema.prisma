generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

// Singleton row (fixed id) holding store-wide configuration — support contact, GSTIN, shop address.
model StoreSettings {
  id           String   @id @default("store")
  supportPhone String?
  supportEmail String?
  gstNumber    String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String   @default("India")
  updatedAt    DateTime @updatedAt

  @@map("store_settings")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  UPI
  UPI_PERSONAL
  CARD
  CASH
}

enum OrderChannel {
  ONLINE
  POS
}

enum DeliveryMethod {
  HOME_DELIVERY
  PICKUP
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  firstName       String?
  lastName        String?
  phone           String?
  role            Role      @default(CUSTOMER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  addresses Address[]
  orders    Order[]
  cartItems CartItem[]

  @@map("users")
}

model EmailOtp {
  id         String    @id @default(uuid())
  email      String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@map("email_otps")
}

model Address {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("India")
  phone      String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  orders Order[]

  @@map("addresses")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  description     String
  price           Decimal  @db.Decimal(10, 2)
  compareAtPrice  Decimal? @db.Decimal(10, 2)
  stock           Int      @default(0)
  images          String[]
  barcode         String?  @unique
  gstRate         Decimal  @default(0) @db.Decimal(5, 2)
  gstInclusive    Boolean  @default(true)
  isActive        Boolean  @default(false)
  isFeatured      Boolean  @default(false)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart_items")
}

model Order {
  id          String       @id @default(uuid())
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])
  addressId   String?
  address     Address?     @relation(fields: [addressId], references: [id])
  channel     OrderChannel @default(ONLINE)
  guestName   String?
  guestPhone  String?
  deliveryMethod DeliveryMethod @default(HOME_DELIVERY)
  contactPhone   String?
  status      OrderStatus  @default(PENDING)
  paymentMethod PaymentMethod
  isPaid      Boolean      @default(false)
  subtotal    Decimal      @db.Decimal(10, 2)
  shippingFee Decimal      @default(0) @db.Decimal(10, 2)
  total       Decimal      @db.Decimal(10, 2)
  trackingCompany String?
  trackingId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  name         String
  price        Decimal @db.Decimal(10, 2)
  quantity     Int
  gstRate      Decimal @default(0) @db.Decimal(5, 2)
  gstInclusive Boolean @default(true)

  @@map("order_items")
}
